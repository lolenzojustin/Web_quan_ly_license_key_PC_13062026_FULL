PROJECT_NAME="License Key Manager"
DATABASE_URL=postgresql+asyncpg://license_user:replace_with_database_password@localhost:5432/license_manager

# Secret key for JWT generation (generate using: openssl rand -hex 32)
SECRET_KEY=replace_with_random_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Initial admin seeding credentials
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin_password_123

# CORS Config
ALLOWED_ORIGINS=["http://localhost:3000"]

# Password change authorization code
PASSWORD_CHANGE_AUTH_CODE=replace_with_a_separate_strong_secret
